{
    "name": "Wallust",
    "type": "dark",
    "colors": {
        "editor.background": "{{background}}",
        "editor.foreground": "{{foreground}}",
        "sideBar.background": "{{color0}}",
        "sideBar.foreground": "{{foreground}}",
        "activityBar.background": "{{background}}",
        "activityBar.foreground": "{{foreground}}",
        "statusBar.background": "{{color0}}",
        "statusBar.foreground": "{{foreground}}",
        "terminal.background": "{{background}}",
        "terminal.foreground": "{{foreground}}"
    },
    "tokenColors": [
        { "scope": "keyword", "settings": { "foreground": "{{color5}}", "fontStyle": "bold" } },
        { "scope": "string", "settings": { "foreground": "{{color2}}" } },
        { "scope": "entity.name.function", "settings": { "foreground": "{{color4}}" } },
        { "scope": "comment", "settings": { "foreground": "{{color8}}", "fontStyle": "italic" } },
        { "scope": "constant.numeric", "settings": { "foreground": "{{color3}}" } },
        { "scope": "variable", "settings": { "foreground": "{{foreground}}" } }
    ]
}
